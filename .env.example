# Optional — enables real email delivery from the Opportunity Desk.
# Without these, the form falls back to opening the visitor's mail app.
RESEND_API_KEY=
FROM_EMAIL=

# Required for private visitor analytics dashboard (/admin/login)
ANALYTICS_DASHBOARD_PASSWORD=

# Optional hardening secret for admin session cookie signing
ANALYTICS_DASHBOARD_SECRET=

# Optional custom storage path for visit data
# ANALYTICS_DATA_FILE=.data/visitor-analytics.json

# Production analytics storage for Vercel KV / Upstash Redis REST.
# Required for durable real-time analytics on Vercel.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional custom Redis key for analytics records.
# ANALYTICS_KV_KEY=portfolio:visitor-analytics:v1
